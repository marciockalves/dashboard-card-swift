<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Dashboard</title>
</head>
<body>
    <div class="d-flex">
        <nav class="bg-primary text-white vh-100 p-3" style="width: 250px;">
            <h4>Menu</h4>
            <ul class="nav flex-column">
                <li class="nav-item"><a href="#" class="nav-link text-white" data-bs-toggle="modal" data-bs-target="#cardModal">Criar novo card</a></li>
                <li class="nav-item"><a href="/logout" class="nav-link text-white">Sair</a></li>
            </ul>
        </nav>
        
        <div class="flex-grow-1">
            <nav class="navbar navbar-light bg-light border-bottom p-3">
                <span class="navbar-brand mb-0 h1">Meu App Vapor</span>
            </nav>
            <div class="p-4">
                <h2>Bem-vindo, #(user.name)!</h2>
                <div id="card-container">
                    </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="cardModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="/cards" method="POST">
                    <div class="modal-header"><h5>Novo Card</h5></div>
                    <div class="modal-body">
                        <input type="text" name="title" class="form-control mb-2" placeholder="Título">
                        <textarea name="content" class="form-control" placeholder="Conteúdo"></textarea>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Salvar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>